# Django
SECRET_KEY=unsafe-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///test.db

# Redis
REDIS_URL=redis://localhost:6379/0

# SMS
SMS_BACKEND=apps.core.sms.backends.console.ConsoleSMSBackend
OTP_HMAC_SECRET=dev-hmac-secret

# AWS S3 Storage
AWS_STORAGE_BUCKET_NAME=namma-neighbor-dev
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Region is hardcoded to ap-south-1 in base.py — no env var needed

# Razorpay (split 03 — seller onboarding)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=  # REQUIRED — app will crash on startup if missing

# Surepass FSSAI API (split 03 — seller onboarding)
SUREPASS_TOKEN=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
